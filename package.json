{
  "name": "pixelhq-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:next": "next dev",
    "dev:server": "tsx watch server/index.ts",
    "dev:worker": "tsx watch server/workers/worker.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:next\"",
    "build": "next build && tsc -p server/tsconfig.json",
    "start": "concurrently \"npm run start:fastify\" \"next start\"",
    "start:fastify": "node server/dist/index.js"
    "postinstall": "prisma generate",
    "migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@fastify/cors": "^9.0.1",
    "bullmq": "^5.7.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.0",
    "dotenv": "^16.4.5",
    "next": "^15.0.7",
    "react": "^19.0.0-rc.0",
    "react-dom": "^19.0.0-rc.0",
    "zustand": "^4.5.2",
    "@tanstack/react-query": "^5.37.1",
    "framer-motion": "^11.0.3",
    "reactflow": "^11.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "concurrently": "^8.2.2",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.38",
    "autoprefixer": "^10.4.19",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}
